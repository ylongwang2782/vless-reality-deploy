# ==========================================
# VLESS + Reality 部署配置文件
# 复制此文件为 config.env 并填写你的配置
# ==========================================

# VPS 服务器配置
VPS_IP="your_vps_ip"
VPS_PASSWORD="your_vps_password"
VPS_USER="root"
VPS_SSH_PORT="22"

# Cloudflare 配置（可选，留空则不配置域名）
CF_API_TOKEN="your_cloudflare_api_token"
CF_DOMAIN="your_domain.com"
CF_SUBDOMAIN="sub"

# 订阅服务器端口
SUB_PORT="8443"

# 节点名称
NODE_NAME="My_Reality"
