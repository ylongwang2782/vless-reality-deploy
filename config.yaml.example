# ==========================================
# VLESS + Reality 多节点配置
# ==========================================
#
# 部署流程：
# 1. ./deploy.sh              - 部署主节点
# 2. ./deploy_node.sh <节点名> - 部署远程节点
# 3. ./sync_users.sh          - 同步用户到所有节点
# 4. ./setup_downloads.sh     - 设置客户端下载（可选）
#

# Cloudflare 配置（推荐，用于隐藏真实IP）
cloudflare:
  api_token: "your_cloudflare_api_token"
  domain: "example.com"
  subdomain: "sub"

# 订阅服务端口
sub_port: 8443

# ==========================================
# 节点配置
# ==========================================
#
# 第一个节点默认为主节点，将托管订阅服务
# 主节点必须配置 ssh 信息
#
# 部署远程节点后，public_key 和 short_id 会自动填充
#

nodes:
  # 主节点 - 香港（示例）
  # 选择线路最稳定的 VPS 作为主节点
  - name: "HK"
    server: "1.2.3.4"
    port: 443
    ssh:
      user: "root"
      password: "your_password"
      port: 22
    # 以下字段部署后自动填充
    public_key: ""
    short_id: ""

  # 远程节点 - 美国（示例）
  - name: "USA"
    server: "5.6.7.8"
    port: 443
    ssh:
      user: "root"
      password: "your_password"
      port: 22
    public_key: ""
    short_id: ""

  # 远程节点 - 荷兰（示例）
  - name: "NL"
    server: "9.10.11.12"
    port: 443
    ssh:
      user: "root"
      password: "your_password"
      port: 22
    public_key: ""
    short_id: ""

  # 添加更多节点...
  # - name: "JP"
  #   server: "x.x.x.x"
  #   port: 443
  #   ssh:
  #     user: "root"
  #     password: "password"
  #     port: 22
  #   public_key: ""
  #   short_id: ""
