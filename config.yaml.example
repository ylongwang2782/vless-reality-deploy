# ==========================================
# VLESS + Reality 多节点配置
# ==========================================

# 主 VPS 配置（托管订阅服务的服务器）
main_vps:
  ip: "your_main_vps_ip"
  user: "root"
  password: "your_password"
  ssh_port: 22

# Cloudflare 配置（可选）
cloudflare:
  api_token: "your_cf_api_token"
  domain: "example.com"
  subdomain: "sub"

# 订阅服务端口
sub_port: 8443

# 节点列表
# type:
#   - "local": 主 VPS 上的节点，自动读取配置
#   - "remote": 远程 VPS 节点，需要提供连接信息
nodes:
  # 主节点（必须是 local 类型，部署在 main_vps 上）
  - name: "USA"
    type: "local"
    # local 类型会自动从主 VPS 的 xray 配置读取

  # 远程节点示例
  - name: "Nether"
    type: "remote"
    server: "45.32.236.112"
    port: 443
    # 以下信息需要从远程 VPS 获取（运行 xray x25519 生成）
    public_key: "your_public_key"
    short_id: "your_short_id"
    # 可选：如果需要自动同步用户，提供 SSH 信息
    ssh:
      user: "root"
      password: "your_password"
      port: 22

  # 更多节点...
  # - name: "Japan"
  #   type: "remote"
  #   server: "xxx.xxx.xxx.xxx"
  #   port: 443
  #   public_key: "xxx"
  #   short_id: "xxx"
